# ============================================================
# Apboa 单机体验版 环境配置（.env.simple）
# 使用方式：由 start-simple.sh 自动复制为 .env
# 所有服务部署在同一台机器上，HOST 均指向容器名
# ============================================================

# ==================== MySQL 配置 ====================
MYSQL_HOST=apboa-mysql
MYSQL_PORT=3306
MYSQL_DATABASE=apboa_next
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_ROOT_PASSWORD=root

# ==================== Redis 配置 ====================
REDIS_HOST=apboa-redis
REDIS_PORT=6379
REDIS_PASSWORD=redis
REDIS_DATABASE=7

# ==================== 向量库配置 ====================
VECTOR_STORE_TYPE=pgvector

# pgvector 配置（VECTOR_STORE_TYPE=pgvector 时生效）
PG_HOST=apboa-pgvector
PG_PORT=5432
PG_DATABASE=apboa_vector
PG_USER=postgres
PG_PASSWORD=postgres

# ==================== 镜像仓库配置 ====================
# Docker 镜像私有仓库前缀，留空则使用 Docker Hub
# 示例: DOCKER_REGISTRY=docker.your-company.com/
DOCKER_REGISTRY=

# ==================== 后端配置 ====================
JWT_SECRET=ZJr8c2xF0y5b7yM+1H9v9cGZq6nZ5e0k5r3Cw7H8vJQ=

# console 资源限制
CONSOLE_MEM_LIMIT=2g
CONSOLE_CPU_LIMIT=4
CONSOLE_JAVA_HEAP_PERCENTAGE=75.0

# runtime 资源限制
RUNTIME_MEM_LIMIT=4g
RUNTIME_CPU_LIMIT=4
RUNTIME_JAVA_HEAP_PERCENTAGE=75.0

# ==================== 前端配置 ====================
FRONTEND_PORT=80
VITE_APP_BASE_API=/web
VITE_APP_CONTEXT_PATH=/web


# ==================== Shell 执行代理配置 ====================
SHELLPROXY_MEM_LIMIT=1g
SHELLPROXY_CPU_LIMIT=2
SHELLPROXY_PIDS_LIMIT=200
SHELLPROXY_DEFAULT_TIMEOUT=300
SHELLPROXY_MAX_TIMEOUT=3600
SHELLPROXY_MAX_OUTPUT_SIZE=52428800
SHELLPROXY_JAVA_HEAP_PERCENTAGE=50.0

# ==================== WebSocket 服务配置 ====================
# WebSocket 服务地址（供 console/runtime 连接）
WEBSOCKET_ENABLED=true
WEBSOCKET_HOST=apboa-websocket
WEBSOCKET_PORT=3064

# websocket 资源限制
WEBSOCKET_MEM_LIMIT=1g
WEBSOCKET_CPU_LIMIT=2
WEBSOCKET_JAVA_HEAP_PERCENTAGE=50.0

# ==================== Workspace 配置 ====================
WORKSPACE_CAPACITY_MB=30

# ==================== 路径配置 ====================
# DATA_PATH=./data
# LOG_PATH=./logs
