<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>com.hxh.apboa.next</groupId>
  <artifactId>apboa-next</artifactId>
  <version>1.0-SNAPSHOT</version>
  <packaging>pom</packaging>
  <modules>
    <!-- 基础层 -->
    <module>common</module>
    <!-- 基础设施 -->
    <module>heartbeat</module>
    <!-- 业务层 -->
    <module>biz</module>
    <!-- 引擎层 -->
    <module>engine</module>
    <!-- 调度层 -->
    <module>scheduler</module>
    <!-- 应用层 -->
    <module>runner-console</module>
    <module>runner-runtime</module>
    <module>runner-proxy</module>
    <module>runner-file</module>
    <module>runner-websocket</module>
    <module>common-base</module>
    <module>workflow</module>
  </modules>

  <properties>
    <maven.compiler.source>21</maven.compiler.source>
    <maven.compiler.target>21</maven.compiler.target>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <spring-boot.version>3.4.9</spring-boot.version>
    <agentscope.version>1.0.12</agentscope.version>
    <mybatis-plus.version>3.5.7</mybatis-plus.version>
    <mysql.java>8.0.33</mysql.java>
    <druid.version>1.2.19</druid.version>
    <lombok.version>1.18.30</lombok.version>
    <groovy.version>4.0.14</groovy.version>
    <guava.version>31.1-jre</guava.version>
    <jjwt.version>0.13.0</jjwt.version>
    <commons-net.version>3.9.0</commons-net.version>
    <aws.version>1.11.543</aws.version>
    <commons-net.version>3.6</commons-net.version>
    <hutool.version>5.8.4</hutool.version>
    <junit.version>3.8.1</junit.version>
  </properties>

  <dependencyManagement>
    <dependencies>
      <!--spring-boot框架-->
      <dependency>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-dependencies</artifactId>
        <version>${spring-boot.version}</version>
        <type>pom</type>
        <scope>import</scope>
      </dependency>
      <!-- mybatis-plus框架 -->
      <dependency>
        <groupId>com.baomidou</groupId>
